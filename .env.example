# WhatsApp
OWNER_PHONE=972XXXXXXXXX        # Your primary number (international format, no +)
BOT_NAME=מקס                    # Agent display name — used in group @mentions

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Railway PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/dbname

# Google OAuth
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Search (Tavily)
TAVILY_API_KEY=tvly-...

# Voice transcription (Groq — free tier, whisper-large-v3)
GROQ_API_KEY=gsk_...
# TTS (gTTS — free, no key needed)

# Service URLs (internal)
WHATSAPP_SERVICE_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Scheduling (Asia/Jerusalem timezone)
TIMEZONE=Asia/Jerusalem
MORNING_SUMMARY_HOUR=8
WEEKLY_SUMMARY_DAY=4     # 0=Monday … 4=Friday
WEEKLY_SUMMARY_HOUR=17
REMINDER_CHECK_HOURS=4
REMINDER_THRESHOLD_HOURS=6

# Limits
CLAUDE_RATE_LIMIT_PER_HOUR=100
