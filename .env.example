# WhatsApp
OWNER_PHONE=972XXXXXXXXX        # Owner's number — used to identify owner in messages
AGENT_PHONE=972XXXXXXXXX        # WhatsApp account running the bot (used for pairing code).
                                # Leave empty to use OWNER_PHONE (when owner IS the bot account)
BOT_NAME=מקס                    # Agent display name — used in group @mentions

# Baileys bridge
WHATSAPP_SERVICE_URL=http://localhost:3000
USE_PAIRING_CODE=false          # Set true to use pairing code instead of QR
PROXY_URL=                      # Optional: socks5://user:pass@host:port  or  http://user:pass@host:port

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Railway PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/dbname

# Google OAuth
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Web chat
WEB_CHAT_PASSWORD=your_secret_password

# Telegram bot (from @BotFather / @userinfobot)
TELEGRAM_BOT_TOKEN=
OWNER_TELEGRAM_ID=

# Search (Tavily)
TAVILY_API_KEY=tvly-...

# Voice transcription (Groq — free tier, whisper-large-v3)
GROQ_API_KEY=gsk_...

# Service URLs
BACKEND_URL=http://localhost:8000

# Scheduling (Asia/Jerusalem timezone)
TIMEZONE=Asia/Jerusalem
MORNING_SUMMARY_HOUR=8
WEEKLY_SUMMARY_DAY=4            # 0=Monday … 4=Friday
WEEKLY_SUMMARY_HOUR=17

# Limits
CLAUDE_RATE_LIMIT_PER_HOUR=100
